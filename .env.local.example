# Copy this file to `.env.local` and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Use your project's client key. Newer Supabase projects show a
# "publishable" key (sb_publishable_...). Older ones show an "anon public" key.
# Set whichever one your dashboard gives you:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
