# Copy this file to `.env.local` and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Use your project's client key. Newer Supabase projects show a
# "publishable" key (sb_publishable_...). Older ones show an "anon public" key.
# Set whichever one your dashboard gives you:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR-PUBLISHABLE-KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---- Firebase (Google login) ----
# Firebase Console → Project settings → General → "Your apps" → Web app → SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR-FIREBASE-API-KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR-PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR-SENDER-ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR-APP-ID
